# ============================================================
# Bug Hunter v4 — server .env
# ============================================================
# Copy this file to `.env` and edit the values you care about.
# After any change here:
#   docker compose down && docker compose up -d
# (no rebuild needed for env-only changes)


# --- App identity ---
APP_VERSION=4.0.0


# --- Public URL (used in invitation / password-reset email links) ---
APP_BASE_URL=http://localhost:8765


# ============================================================
# Authentication
# ============================================================

# Long random string used to sign session cookies.
# Generate with: openssl rand -hex 32
# REQUIRED in production. A fallback is auto-generated for dev but
# rotates every restart, which means every cookie immediately expires.
SESSION_SECRET=

# Session lifetime in seconds. 86400 = 1 day.
SESSION_TTL_SECONDS=86400

# Set to true ONLY when serving over HTTPS (real cert).
# If true on plain HTTP, the cookie won't be sent and login will silently break.
COOKIE_SECURE=false

# bcrypt cost factor. 10 ≈ 100ms on a modern core, fine for 0.1-vCPU.
# Raise to 12 if you have CPU headroom. Below 8 is not recommended.
BCRYPT_ROUNDS=10


# ============================================================
# Multi-tenant signup
# ============================================================

# When true, anyone can hit /signup and create their own organization,
# becoming its first admin. When false, /signup returns 403 — useful for
# private installs where only invited users should join.
ALLOW_PUBLIC_SIGNUP=true


# ============================================================
# Email (Gmail / SMTP)
# ============================================================
# EMAIL_BACKEND options:
#   console   (default) Logs every email to stdout. Good for dev.
#   smtp      Sends real email via the SMTP_* settings below.
#   disabled  No-op.
EMAIL_BACKEND=console
EMAIL_FROM=Bug Hunter <bugtracker@localhost>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false


# ============================================================
# Sleuth — built-in AI assistant (no config needed by default)
# ============================================================
# Sleuth runs out of the box with no extra environment variables. It
# uses rule-based parsing + a small statistical classifier — both
# pure Python, both fit in the default 512 MB memory cap.
#
# The optional Layer 3 LLM (local llama.cpp) requires a GGUF model
# file at models/sleuth.gguf AND a higher memory limit in
# docker-compose.yml. If you don't enable it, Sleuth still works.
# See README.md and models/README.md for setup instructions.
